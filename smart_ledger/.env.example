# Smart Ledger Configuration

# Savings / FIRE goals
# GOAL_TARGET=1000000
# GOAL_DEADLINE=2036-05
# FIRE_ANNUAL_RETURN_PCT=7.0

# Stock P&L sync — which savings goal receives investment gains
# STOCK_PNL_GOAL_ID=1
# STOCK_PNL_GOAL_NAME=30岁之前赚到100万
# STOCK_PNL_GOAL_TARGET=1000000
# STOCK_PNL_GOAL_DEADLINE=2036-05
# STOCK_PNL_GOAL_COLOR=#0d7377

# Smart Ledger AI Configuration

# Option 1: Xiaomi MiLM (default)
LLM_BASE_URL=https://api.xiaomi.com/v1
LLM_MODEL=MiLM
LLM_API_KEY=your_api_key_here

# Option 2: Ollama (local)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5
# LLM_API_KEY=ollama

# Option 3: OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-xxx

# Option 4: DeepSeek
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=sk-xxx
